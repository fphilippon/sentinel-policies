organization        = "your-hcp-terraform-org"
vcs_repo_identifier = "fphilippon/sentinel-policies"
vcs_branch          = "main"

policy_sets = {
  global-governance = {
    description   = "Pilot Sentinel policy set for common governance controls."
    policies_path = "policy-sets/global-governance"
  }
  gcp-baseline = {
    description   = "GCP security baseline controls for public exposure and managed-service hardening."
    policies_path = "policy-sets/gcp-baseline"
  }
}

# Use the connection style configured in your HCP Terraform organization.
# GitHub App path, preferred for GitHub.com and HCP Terraform remote runs.
github_app_installation_id = "ghain-xxxxxxxxxxxxxxxx"

# Optional lookup paths for local runs with a user API token.
# github_app_installation_number = 12345678
# github_app_installation_name = "github-user-or-org"

# Legacy OAuth path, only when the organization uses OAuth VCS providers.
# oauth_token_id = "ot-xxxxxxxxxxxxxxxx"

# Prefer project scope for the pilot project.
project_ids = ["prj-xxxxxxxxxxxxxxxx"]

# Use workspace scope instead if the customer explicitly requires workspace-level attachment.
# workspace_ids = ["ws-xxxxxxxxxxxxxxxx"]
